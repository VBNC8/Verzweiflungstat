/ {
    leds {
        compatible = "gpio-leds";
        status_led: led_0 {
            gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>;
            label = "Status LED";
        };
    };
};

// In deiner splitkb_aurora_corne_left.overlay
/ {
    status_led: status_led {
        compatible = "zmk,output-behavior-generic";
        #binding-cells = <1>;
        gpio-pin = <&gpio0 6 GPIO_ACTIVE_HIGH>;
    };
};

// Falls dein Encoder links verbaut ist
&left_encoder {
    status = "okay";
};
