/ {
    chosen {
        zmk,backlight = &backlight;
    };

    backlight: backlight {
        compatible = "gpio-backlight";
        // Hier KEIN GPIO-Pin direkt im Hauptknoten
        
        led_0 {
            gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
        };
    };
};

&left_encoder {
    status = "okay";
};
