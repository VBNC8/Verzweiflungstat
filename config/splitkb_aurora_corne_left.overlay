/ {
    leds {
        compatible = "gpio-leds";
        status_led: led_0 {
            gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
            label = "Status LED";
        };
    };

    /* Wir sagen ZMK, dass dies die 'Haupt-LED' für Statusmeldungen ist */
    chosen {
        zmk,status-led = &status_led;
    };
};
