/ {
    // Hier kannst du später deine LED definieren
    leds {
        compatible = "gpio-leds";
        status_led: led_0 {
            gpios = <&pro_micro 9 GPIO_ACTIVE_HIGH>; // Jetzt gehört der Pin der LED!
            label = "Status LED";
        };
    };
};

// Falls dein Encoder links ist:
&left_encoder {
    status = "okay";
};
