/ {
    leds {
        compatible = "gpio-leds";
        side_led: led_0 {
            gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
            label = "Side Indicator";
        };
    };

    /* Wir verknüpfen die GPIO-LED mit dem Backlight-Modul */
    chosen {
        zmk,backlight = &side_led;
    };
};
