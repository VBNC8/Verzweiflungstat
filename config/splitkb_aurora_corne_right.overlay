/* Wir lassen i2c0 deaktiviert */
&i2c0 { status = "disabled"; };

/ {
    /* Das Dummy-Display verhindert den "ord_174" Fehler */
    chosen {
        zephyr,display = &dummy_dis;
    };

    dummy_dis: dummy_dis {
        compatible = "zephyr,dummy-display";
        status = "okay";
        width = <160>;
        height = <80>;
    };
};

/* Wir nutzen SPI3 statt SPI0, um den Hardware-Konflikt zu umgehen */
&pinctrl {
    spi3_default: spi3_default {
        group1 {
            /* Deine Belegung: SCK = P0.20, MOSI (SI) = P0.08, MISO (SO) = P0.17 */
            psels = <NRF_PSEL(SPIM_SCK, 0, 20)>,  
                    <NRF_PSEL(SPIM_MOSI, 0, 8)>, 
                    <NRF_PSEL(SPIM_MISO, 0, 17)>;
        };
    };
};

&spi3 {
    status = "okay";
    cs-gpios = <&gpio0 22 GPIO_ACTIVE_LOW>; // Prüfe, ob Pin 22 dein CS ist!

    trackpad: trackpad@0 {
        compatible = "cirque,pinnacle";
        reg = <0>;
        spi-max-frequency = <1000000>;
        dr-gpios = <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
    };
};
