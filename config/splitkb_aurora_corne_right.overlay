/* 1. Display-Bus deaktivieren */
&i2c0 {
    status = "disabled";
};

/* 2. SPI-Bus definieren (ohne pinctrl-Umweg für den Test) */
&spi0 {
    status = "okay";
    /* Wir definieren die Pins hier direkt als Eigenschaften */
    /* Die Nummern entsprechen den GPIO-Nummern deines nice!nano */
    sck-pin = <2>;     /* P0.02 (D19) */
    mosi-pin = <17>;    /* P0.17 (D1) */
    miso-pin = <20>;    /* P0.20 (D0) */
    cs-gpios = <&gpio0 8 GPIO_ACTIVE_LOW>; /* P0.08 (D2) */
};
