#include <dt-bindings/pinctrl/nrf-pinctrl.h>
#include <dt-bindings/pinctrl/nrf-pinctrl.h>

/* Wir löschen den Alias und deaktivieren den SPI-Bus, 
   damit die rechte Seite gar nicht erst versucht, Hardware zu finden. */

/ {
    aliases {
        /delete-property/ nice-view-spi;
    };
};

&spi3 {
    status = "disabled";
};

/* Der Rest der Datei kann leer bleiben, da das Basis-Shield 
   die Matrix-Pins für die rechte Seite automatisch setzt. */
