/ {
    // Definition des Pins als Output-Behavior
    status_led: status_led {
        compatible = "zmk,output-behavior-generic";
        #binding-cells = <0>;
        gpio-pin = <&gpio0 29 GPIO_ACTIVE_HIGH>;
    };

    macros {
        led_test: led_test {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            // In Makros schreibt man wait-ms (mit Bindestrich) für die Standardpause
            // oder nutzt wait_ms (ohne &) innerhalb der bindings
            bindings
                = <&macro_param_1to1 &status_led 1> 
                , <&wait_ms 100>                   // KEIN & davor!
                , <&macro_param_1to1 &status_led 0> 
                , <&wait_ms 100>
                , <&macro_param_1to1 &status_led 1>
                , <&wait_ms 100>
                , <&macro_param_1to1 &status_led 0>;
        };
    };
};
