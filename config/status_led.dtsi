/ {
    // Hardware-Definition: Wir sagen Zephyr, dass an P0.29 eine LED hängt.
    leds {
        compatible = "gpio-leds";
        status_led_node: led_0 {
            gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
            label = "Status LED";
        };
    };

    macros {
        // Nur ein Makro: LED an beim Drücken, Pause bis zum Loslassen, LED aus.
        led_on_hold: led_on_hold {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&macro_param_1to1 &status_led_node 1> 
                , <&macro_pause_for_release>        
                , <&macro_param_1to1 &status_led_node 0>; 
        };
    };
};
