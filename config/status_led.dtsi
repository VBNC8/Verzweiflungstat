/ {
    // Definition des GPIO-Verhaltens für P0.29
    status_led: status_led {
        compatible = "zmk,output-behavior-generic";
        #binding-cells = <0>;
        gpio-pin = <&gpio0 29 GPIO_ACTIVE_HIGH>;
    };

    macros {
        // Taste 1: Statischer Check (Leuchtet so lange man drückt)
        led_on_hold: led_on_hold {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_param_1to1 &status_led 1> // LED AN
                , <&macro_pause_for_release>        // Warten auf Loslassen
                , <&macro_param_1to1 &status_led 0>; // LED AUS
        };

        // Taste 2: Blink-Test (2x kurz blitzen)
        led_blink: led_blink {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <100>;
            tap-ms = <100>;
            bindings
                = <&macro_param_1to1 &status_led 1> 
                , <&wait_ms 150>
                , <&macro_param_1to1 &status_led 0> 
                , <&wait_ms 150>
                , <&macro_param_1to1 &status_led 1>
                , <&wait_ms 150>
                , <&macro_param_1to1 &status_led 0>;
        };
    };
};
