/ {
    // Dieser Block definiert die Hardware-Ansteuerung
    behaviors {
        my_led_pin: my_led_pin {
            compatible = "zmk,output-behavior-generic";
            #binding-cells = <0>;
            gpio-pin = <&gpio0 29 GPIO_ACTIVE_HIGH>;
        };
    };

    // Dieser Block definiert die Tastatur-Befehle
    macros {
        led_on_hold: led_on_hold {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings
                = <&macro_param_1to1 &my_led_pin 1> 
                , <&macro_pause_for_release>        
                , <&macro_param_1to1 &my_led_pin 0>; 
        };

        led_blink: led_blink {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <200>; 
            tap-ms = <200>;
            bindings
                = <&macro_param_1to1 &my_led_pin 1> 
                , <&macro_param_1to1 &my_led_pin 0> 
                , <&macro_param_1to1 &my_led_pin 1>
                , <&macro_param_1to1 &my_led_pin 0>;
        };
    };
};
